{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "allowArbitraryExtensions": true,
    "checkJs": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["node", "vite/client"]
  },
  "include": [
    "src/client/**/*.ts",
    "src/client/**/*.tsx",
    "src/client/**/*.d.ts",
    "src/shared/**/*.ts",
    "src/shared/**/*.d.ts"
  ],
  "exclude": [
    "node_modules",
    "release",
    "dist"
  ]
}
