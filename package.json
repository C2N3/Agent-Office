{
  "name": "agent-office",
  "version": "2.0.0",
  "description": "Visualize multi-agent Claude and Codex CLI sessions as pixel avatars in real time",
  "main": "src/main.js",
  "scripts": {
    "postinstall": "node src/install.js",
    "rebuild": "electron-rebuild -f -w node-pty",
    "build:types": "node scripts/build-types.js",
    "prestart": "npm run build:types",
    "start": "node scripts/run-electron.js",
    "predev": "npm run build:types",
    "dev": "node scripts/run-electron.js --dev",
    "typecheck": "node node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "pretest": "npm run build:types",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "predashboard": "npm run build:types",
    "dashboard": "node src/dashboard-server.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.js\" \"__tests__/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\" \"__tests__/**/*.js\"",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "pixel-art",
    "claude-cli",
    "codex-cli",
    "multi-agent",
    "jsonl"
  ],
  "author": "Mgpixelart",
  "homepage": "https://github.com/Mgpixelart/agent-office",
  "repository": {
    "type": "git",
    "url": "https://github.com/Mgpixelart/agent-office.git"
  },
  "license": "MIT",
  "build": {
    "appId": "com.mgpixelart.agent-office",
    "productName": "Agent-Office",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "src/**/*",
      "public/**/*",
      "styles.css",
      "index.html",
      "dashboard.html",
      "package.json",
      "node_modules/node-pty/**/*",
      "node_modules/@xterm/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^3.6.0",
    "@eslint/js": "^9.0.0",
    "@types/electron": "^1.6.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "electron": "^32.0.0",
    "electron-builder": "^25.1.0",
    "eslint": "^9.0.0",
    "jest": "^30.2.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "ajv": "^8.18.0",
    "node-addon-api": "^8.7.0",
    "node-pty": "^1.0.0"
  }
}
