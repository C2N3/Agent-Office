{
  "name": "agent-office",
  "version": "0.1.3",
  "description": "Visualize multi-agent Claude and Codex CLI sessions as pixel avatars in real time",
  "main": "dist/src/main.js",
  "scripts": {
    "postinstall": "node src/install.js",
    "rebuild": "electron-rebuild -f -w node-pty",
    "build:dist": "node scripts/build-types.js",
    "build:dist:watch": "node scripts/build-types.js --watch",
    "build:types": "npm run build:dist",
    "prestart": "npm run build:dist",
    "start": "node scripts/run-electron.js",
    "dev": "node scripts/dev-runtime.js",
    "typecheck": "node node_modules/@typescript/native-preview/bin/tsgo.js -p tsconfig.json --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "predashboard": "npm run build:dist",
    "dashboard": "node dist/src/dashboardServer/index.js",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,ts}\" \"__tests__/**/*.js\" \"scripts/**/*.js\" \"*.js\"",
    "format:check": "prettier --check \"src/**/*.{js,ts}\" \"__tests__/**/*.js\" \"scripts/**/*.js\" \"*.js\"",
    "dist": "electron-builder",
    "dist:win": "npm run build:dist && electron-builder --win --publish never",
    "dist:mac": "npm run build:dist && electron-builder --mac --publish never",
    "dist:mac:unsigned": "npm run build:dist && electron-builder --mac --publish never -c.mac.identity=null -c.mac.notarize=false",
    "dist:mac:signed": "node scripts/dist-mac-signed.js",
    "dist:linux": "npm run build:dist && electron-builder --linux --publish never"
  },
  "keywords": [
    "electron",
    "pixel-art",
    "claude-cli",
    "codex-cli",
    "multi-agent",
    "jsonl"
  ],
  "author": "C2N3",
  "homepage": "https://github.com/C2N3/Agent-Office",
  "repository": {
    "type": "git",
    "url": "https://github.com/C2N3/Agent-Office.git"
  },
  "license": "MIT",
  "build": {
    "appId": "com.c2n3.agent-office",
    "productName": "Agent-Office",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "node_modules/node-pty/**/*",
      "node_modules/@xterm/**/*"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Development"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "Agent-Office.${version}.${ext}"
    }
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^10.0.1",
    "@types/electron": "^1.6.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "eslint": "^10.2.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.2",
    "@typescript/native-preview": "7.0.0-dev.20260410.1"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "ajv": "^8.18.0",
    "node-addon-api": "^8.7.0",
    "node-pty": "^1.1.0"
  }
}
