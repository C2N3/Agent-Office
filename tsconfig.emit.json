{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowJs": false,
    "checkJs": false,
    "noEmit": false,
    "declaration": false,
    "sourceMap": false,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.d.ts",
    "public/**/*.ts",
    "public/**/*.tsx",
    "public/**/*.d.ts"
  ],
  "exclude": [
    "__tests__/**/*",
    "dist/**/*",
    "release/**/*"
  ]
}
